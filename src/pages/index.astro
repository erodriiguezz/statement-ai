---
import Layout from "../layouts/Layout.astro";
import StatementParser from "../components/StatementParser.jsx";
import PDFParserReact from "../components/PDFParserReact";
---

<Layout>
  <main class="max-w-5xl mx-auto px-6 py-12">
    <header class="mb-10">
      <h1 class="text-3xl font-semibold mb-2">Client Statement Intake</h1>
      <p class="text-gray-600">
        Internal tool to ingest client statements and generate structured
        summaries for tax preparation.
      </p>
    </header>

    <StatementParser client:load />
  </main>
</Layout>
