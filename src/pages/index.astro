---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="max-w-5xl mx-auto px-6 py-12">
    <header class="mb-10">
      <h1 class="text-3xl font-semibold mb-2">Client Statement Intake</h1>
      <p class="text-gray-600">
        Internal tool to ingest client statements and generate structured
        summaries for tax preparation.
      </p>
    </header>

    <section class="bg-white rounded-xl shadow p-8">
      <form class="space-y-8">
        <!-- Client Info -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium mb-2">Client Name</label>
            <input
              type="text"
              placeholder="John Doe"
              class="w-full rounded-lg border-gray-300 focus-visible:outline-none focus:border-gray-900 focus:ring-gray-900"
            />
          </div>

          <div>
            <label class="block text-sm font-medium mb-2">Tax Year</label>
            <select
              class="w-full rounded-lg border-gray-300 focus-visible:outline-none focus:border-gray-900 focus:ring-gray-900"
            >
              <option>2025</option>
              <option>2024</option>
              <option>2023</option>
            </select>
          </div>
        </div>

        <!-- Statement Type -->
        <!-- <div>
            <label class="block text-sm font-medium mb-2">Statement Type</label>
            <select class="w-full rounded-lg border-gray-300 focus:border-gray-900 focus:ring-gray-900">
              <option>Bank Statement</option>
              <option>Credit Card Statement</option>
              <option>Payroll / Income Statement</option>
              <option>Business Expense Statement</option>
              <option>Other</option>
            </select>
          </div> -->

        <!-- File Upload -->
        <div>
          <label class="block text-sm font-medium mb-2"
            >Upload PDF Statements</label
          >
          <input
            type="file"
            accept="application/pdf"
            multiple
            class="block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-gray-900 file:text-white hover:file:bg-gray-800 file:cursor-pointer"
          />
          <p class="text-xs text-gray-500 mt-2">
            Multiple PDFs supported. Files are processed temporarily and deleted
            after summary generation.
          </p>
        </div>

        <!-- Consent -->
        <!-- <div class="flex items-start gap-3">
            <input type="checkbox" id="consent" class="mt-1" />
            <label for="consent" class="text-sm text-gray-700">
              I confirm this is an internal client document and authorize temporary AI processing for tax preparation.
            </label>
          </div> -->

        <!-- Submit -->
        <button
          type="submit"
          class="w-full bg-gray-900 text-white py-3 rounded-lg font-medium hover:bg-gray-800 transition cursor-pointer"
        >
          Process Statements
        </button>
      </form>
    </section>

    <!-- Output Preview -->
    <section class="mt-12">
      <h2 class="text-xl font-semibold mb-4">Generated Summary</h2>

      <div class="bg-white rounded-xl shadow p-6 mb-6">
        <h3 class="text-lg font-medium mb-3">Totals</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
          <div class="p-4 bg-gray-50 rounded-lg">
            <p class="text-gray-500">Total Income</p>
            <p class="text-xl font-semibold">$0.00</p>
          </div>
          <div class="p-4 bg-gray-50 rounded-lg">
            <p class="text-gray-500">Total Expenses</p>
            <p class="text-xl font-semibold">$0.00</p>
          </div>
          <div class="p-4 bg-gray-50 rounded-lg">
            <p class="text-gray-500">Net Result</p>
            <p class="text-xl font-semibold">$0.00</p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow p-6">
        <h3 class="text-lg font-medium mb-4">Categorized Breakdown</h3>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead class="border-b">
              <tr class="text-left">
                <th class="py-2">Category</th>
                <th class="py-2">Amount</th>
                <th class="py-2">Type</th>
                <th class="py-2">Notes</th>
              </tr>
            </thead>
            <tbody class="divide-y">
              <tr>
                <td class="py-2">Office Supplies</td>
                <td class="py-2">$0.00</td>
                <td class="py-2">Expense</td>
                <td class="py-2 text-gray-500">Auto-detected</td>
              </tr>
              <tr>
                <td class="py-2">Meals</td>
                <td class="py-2">$0.00</td>
                <td class="py-2">Expense</td>
                <td class="py-2 text-gray-500">Possible deductible</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </main>
</Layout>
